generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  emailLogs    EmailLog[]
  jobs         Job[]

  @@index([role])
}

model Job {
  id              String   @id @default(uuid())
  userId          String

  companyName     String
  roleTitle       String

  salaryMin       Int?
  salaryMax       Int?

  status          JobStatus
  priority        PriorityLevel

  applicationDate DateTime
  interviewDate   DateTime?

  notes           String?

  resumeUrl       String?

  isDeleted       Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])

  // ✅ ADD THESE RELATIONS
  jobTags         JobTag[]
  files           File[]
  emailLogs       EmailLog[]
}

model Tag {
  id   String   @id @default(uuid())
  name String   @unique
  jobs JobTag[]
}

model JobTag {
  jobId String
  tagId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
}

model File {
  id         String   @id @default(uuid())
  jobId      String
  fileUrl    String
  publicId   String
  uploadedAt DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model EmailLog {
  id        String   @id @default(uuid())

  userId    String
  jobId     String

  type      String   // ✅ ADD THIS
  status    String

  sentAt    DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
}

enum JobStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}


